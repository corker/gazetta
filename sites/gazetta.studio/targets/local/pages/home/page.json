{
  "template": "site-layout",
  "metadata": {
    "title": "Gazetta — Stateless CMS for Composable Websites",
    "description": "No database. No build step. Pages composed from reusable components at serve time."
  },
  "components": [
    "@header",
    {
      "name": "hero",
      "template": "hero",
      "content": {
        "badge": "Open Source — MIT License",
        "badgeHref": "https://github.com/gazetta-studio/gazetta-studio",
        "title": "The CMS that stores nothing",
        "subtitle": "Gazetta is a stateless CMS where pages are composed from reusable components. No database, no build step. Deploy to Cloudflare Workers, your own server, or any Node.js host.",
        "cta": "Get Started",
        "ctaHref": "/docs"
      }
    },
    {
      "name": "how-it-works",
      "template": "section",
      "content": {
        "heading": "How it works",
        "subheading": "Three concepts. That's it."
      },
      "components": [
        {
          "name": "cards",
          "template": "feature-grid",
          "components": [
            {
              "name": "comp",
              "template": "feature-card",
              "content": {
                "icon": "🧩",
                "title": "Components",
                "description": "Everything is a component. Each has a template, content, and optional children. Templates are pure functions — use React, Svelte, Vue, or plain TypeScript."
              }
            },
            {
              "name": "frag",
              "template": "feature-card",
              "content": {
                "icon": "🔗",
                "title": "Fragments",
                "description": "Shared components reusable across pages. Update a header fragment once — every page reflects it instantly. No rebuild needed."
              }
            },
            {
              "name": "target",
              "template": "feature-card",
              "content": {
                "icon": "🎯",
                "title": "Targets",
                "description": "Content lives in storage targets — S3, Azure Blob, or filesystem. The CMS is stateless and disposable. Lose it, spin up a new one."
              }
            }
          ]
        },
        {
          "name": "example",
          "template": "code-block",
          "content": {
            "language": "TypeScript",
            "code": "// templates/hero/index.ts\nimport { z } from 'zod'\nimport type { TemplateFunction } from 'gazetta'\n\nexport const schema = z.object({\n  title: z.string(),\n  subtitle: z.string().optional(),\n})\n\ntype Content = z.infer<typeof schema>\n\nconst template: TemplateFunction<Content> = ({ content }) => ({\n  html: `<h1>${content?.title}</h1>`,\n  css: `h1 { font-size: 3rem; }`,\n  js: '',\n})\n\nexport default template"
          }
        }
      ]
    },
    {
      "name": "comparison",
      "template": "section",
      "content": {
        "heading": "Why not a traditional CMS?"
      },
      "components": [
        {
          "name": "table",
          "template": "comparison-table",
          "content": {
            "rows": [
              {
                "label": "Storage",
                "traditional": "Database (MySQL, Postgres)",
                "gazetta": "S3, Azure Blob, or plain files"
              },
              {
                "label": "Publishing",
                "traditional": "Full site rebuild",
                "gazetta": "Publish one fragment, all pages update"
              },
              {
                "label": "CMS goes down",
                "traditional": "Content is lost or locked",
                "gazetta": "Spin up a new one, connect to targets"
              },
              {
                "label": "Templates",
                "traditional": "One framework (React OR Vue)",
                "gazetta": "Any framework per template"
              },
              {
                "label": "Shared header",
                "traditional": "Rebuild every page",
                "gazetta": "Update once, instant everywhere"
              },
              {
                "label": "Data flow",
                "traditional": "One-way: CMS → deploy",
                "gazetta": "Bidirectional: push and pull"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "quick-start",
      "template": "section",
      "content": {
        "heading": "Quick start",
        "subheading": "From zero to a running site in 30 seconds."
      },
      "components": [
        {
          "name": "install-code",
          "template": "terminal",
          "content": {
            "title": "~/projects",
            "lines": [
              {
                "command": "npx gazetta init my-site",
                "delay": 300
              },
              {
                "output": "  {green}Created{/} my-site/",
                "delay": 400
              },
              {
                "output": "  {dim}Installing dependencies...{/}",
                "delay": 800
              },
              {
                "output": "  {green}Dependencies installed{/}",
                "delay": 400
              },
              {
                "command": "cd my-site && npx gazetta dev",
                "delay": 500
              },
              {
                "output": "  {badge} gazetta {/} {green}my-site{/} {dim}ready in 120 ms{/}",
                "delay": 300
              },
              {
                "output": ""
              },
              {
                "output": "  {dim}┃{/} Local    {cyan}http://localhost:3000/{/}"
              },
              {
                "output": "  {dim}┃{/} CMS      {cyan}http://localhost:3000/admin{/}"
              }
            ]
          }
        }
      ]
    },
    "@footer"
  ]
}
