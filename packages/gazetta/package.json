{
  "name": "gazetta",
  "version": "0.3.0",
  "description": "Stateless CMS for composable websites",
  "keywords": [
    "cms",
    "stateless",
    "composable",
    "hono",
    "templates",
    "fragments",
    "ssr"
  ],
  "homepage": "https://gazetta.studio",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist/",
    "admin-dist/"
  ],
  "bin": {
    "gazetta": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./editor": {
      "types": "./dist/editor/mount.d.ts",
      "import": "./dist/editor/mount.js"
    },
    "./admin-api": {
      "types": "./dist/admin-api/index.d.ts",
      "import": "./dist/admin-api/index.js"
    },
    "./workers/cloudflare-r2": {
      "types": "./dist/workers/cloudflare-r2.d.ts",
      "import": "./dist/workers/cloudflare-r2.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gazetta-studio/gazetta-studio.git",
    "directory": "packages/gazetta"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "build:admin": "vite build -c ../../apps/admin/vite.config.ts --base /admin/ --outDir ../../packages/gazetta/admin-dist --emptyOutDir ../../apps/admin",
    "prepublishOnly": "npm run build && npm run build:admin",
    "test": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@floating-ui/dom": "^1.7.6",
    "@hello-pangea/dnd": "^18.0.1",
    "@hono/node-server": "^1.19.14",
    "@rjsf/core": "^6.4.0",
    "@rjsf/utils": "^6.4.0",
    "@rjsf/validator-ajv8": "^6.4.0",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "hono": "^4.12.0",
    "jiti": "^2.6.1",
    "js-yaml": "^4.1.0",
    "marked": "^18.0.0",
    "postcss": "^8.5.8",
    "postcss-prefix-selector": "^2.1.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": ">=3",
    "@azure/storage-blob": ">=12",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@azure/storage-blob": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@azure/storage-blob": "^12.31.0",
    "@cloudflare/workers-types": "^4.20260413.1",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.0"
  }
}
